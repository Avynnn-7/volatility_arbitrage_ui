# ============================================================
# VOL-ARB ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git — it is gitignored.
# ============================================================

# --- Upstox API Credentials ---
# Get these from: https://developer.upstox.com/
# Required scopes: market:read, data.option_chain:read
UPSTOX_API_KEY=ENTER_YOUR_API_KEY_HERE
UPSTOX_API_SECRET=ENTER_YOUR_API_SECRET_HERE

# Access Token (changes daily — generated via OAuth flow)
# Format: Bearer <jwt_token>  OR just the raw JWT
UPSTOX_ACCESS_TOKEN=ENTER_YOUR_ACCESS_TOKEN_HERE

# Upstox OAuth Redirect URI (must match what you registered)
UPSTOX_REDIRECT_URI=http://localhost:3001/api/upstox/callback

# --- Server Configuration ---
PORT=3001

# --- Frontend (Vite) Configuration ---
# URL of the Node.js backend — used by the React app
VITE_API_URL=http://localhost:3001/api

# --- Feature Flags ---
# Set to "true" to log all Upstox API calls to console (verbose)
UPSTOX_DEBUG=false

# Set to "true" to use local sample_quotes.json instead of live API
# Useful for UI development without a valid token
USE_MOCK_DATA=false
