# ============================================================================
# Docker Ignore File
# Files and directories to exclude from Docker build context
# ============================================================================

# Dependencies
node_modules
.pnp
.pnp.js

# Build outputs
dist
build
coverage
test-results

# Development files
.git
.gitignore
.env
.env.local
.env.development
.env.test
.env.production.local

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Testing
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
__mocks__

# Documentation
README.md
CHANGELOG.md
docs/

# Docker files (prevent recursive copy)
Dockerfile
docker-compose*.yml
.dockerignore

# Misc
*.md
LICENSE
.editorconfig
.prettierrc
.eslintrc*
tsconfig*.json
vitest.config.ts
